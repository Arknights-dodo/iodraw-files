null,"expandState":"expand"},"children":[]}]}]},{"data":{"id":"dgzt022jwr40","created":1773217100169,"text":"应用范围","layout":null},"children":[{"data":{"id":"dgzto1g5am80","created":1773218979554,"text":"综合型","note":"具有透视、摄影和特殊检查等多种功能","layout":null},"children":[]},{"data":{"id":"dgzto5f05k00","created":1773218988192,"text":"专用型","layout":null},"children":[{"data":{"id":"dgztp1o1mc00","created":1773219058395,"text":"乳腺摄影X线机","layout":null},"children":[]},{"data":{"id":"dgztphutuls0","created":1773219093634,"text":"牙科X线机","layout":null},"children":[]},{"data":{"id":"dgztpkmr4ps0","created":1773219099676,"text":"口腔全景X线机","layout":null},"children":[]},{"data":{"id":"dgztpyh0pow0","created":1773219129805,"text":"手术用X线机","layout":null},"children":[]}]}]},{"data":{"id":"dgzt02pq4qw0","created":1773217101570,"text":"结构形式","layout":null},"children":[{"data":{"id":"dgztqrfpoww0","created":1773219192852,"text":"便携式"},"children":[]},{"data":{"id":"dgzts94q3k00","created":1773219309734,"text":"移动式"},"children":[]},{"data":{"id":"dgzts9mbpuo0","created":1773219310798,"text":"固定式"},"children":[]}]},{"data":{"id":"dgzt02vkqbk0","created":1773217101924,"text":"使用目的","layout":null},"children":[{"data":{"id":"dgzts71g2xk0","created":1773219305182,"text":"透视"},"children":[]},{"data":{"id":"dgztskjxjuw0","created":1773219334598,"text":"摄影"},"children":[]},{"data":{"id":"dgztskn3plc0","created":1773219334790,"text":"胃肠"},"children":[]},{"data":{"id":"dgztskpzj5c0","created":1773219334964,"text":"心血管造影"},"children":[]}]},{"data":{"id":"dgzt02y6dtk0","created":1773217102081,"text":"高压整流形式","layout":null,"note":"自整流\n单向半波/全波整流\n三相整流（三相六波、三相十二波）————应用于大型心血管造影机、胃肠机等。\n高频逆变整流————目前几乎所有的新式数字化X线机（DR、移动DR、DSA等）都采用这种方式。"},"children":[{"data":{"id":"dgztu78fiow0","created":1773219462333,"text":"单向自整流X线机","note":"主要用于小型、移动式或齿科X线机。"},"children":[]},{"data":{"id":"dgztuajdf9k0","created":1773219469525,"text":"单向半波整流X线机"},"children":[]},{"data":{"id":"dgztuhbzln40","created":1773219484316,"text":"单向全波整流X线机","note":"广泛用于30kW以下的中型X线机，如胃肠机、普通拍片机。"},"children":[]},{"data":{"id":"dgztvuxm6bc0","created":1773219592286,"text":"倍压整流X线机"},"children":[]}]},{"data":{"id":"dgzt0310dpk0","created":1773217102252,"text":" ","layout":null},"children":[]}]},{"data":{"id":"dgzt00zljoo0","created":1773217097813,"text":"构成 ","layout":null},"children":[{"data":{"id":"dh0xyfm1nwg0","created":1773332638423,"text":"主机"},"children":[{"data":{"id":"dh0xynlpfmo0","created":1773332655817,"text":"X线管装置"},"children":[{"data":{"id":"dh0y6vdvf340","created":1773333299671,"text":"气体电离式X线管"},"children":[]},{"data":{"id":"dh0y75vp8tc0","created":1773333322517,"text":"固定阳极X线管"},"children":[]},{"data":{"id":"dh0y7b6yyi00","created":1773333334082,"text":"旋转阳极X线管"},"children":[]},{"data":{"id":"dh0y7r6chao0","created":1773333368873,"text":"三极X线管"},"children":[]},{"data":{"id":"dh0y7ubfrjs0","created":1773333375711,"text":"软X线管"},"children":[]}]},{"data":{"id":"dh0xyrbsu2o0","created":1773332663925,"text":"高压发生装置"},"children":[{"data":{"id":"dh0yqwiicrk0","created":1773334869411,"text":"高压变压器"},"children":[]},{"data":{"id":"dh0yqzqwjaw0","created":1773334876449,"text":"X线管灯丝变压器"},"children":[]},{"data":{"id":"dh0yr63fleg0","created":1773334890268,"text":"高压硅堆"},"children":[]},{"data":{"id":"dh0yrd4qpk80","created":1773334905584,"text":"高压变换闸"},"children":[]}]},{"data":{"id":"dh0xyu8wxo00","created":1773332670281,"text":"控制装置"},"children":[]}]},{"data":{"id":"dh0xyijqg6g0","created":1773332644814,"text":"外围装置"},"children":[{"data":{"id":"dh0y4q39gtc0","created":1773333131417,"text":"机械装置"},"children":[{"data":{"id":"dh0y9umbmjs0","created":1773333533098,"text":"诊视床"},"children":[]},{"data":{"id":"dh0ya08msgw0","created":1773333545331,"text":"摄影床与立式摄影架","note":"摄影床由床架和床面组成,床面下配置有活动式滤线器称为滤线器摄影床\n立式摄影架"},"children":[]},{"data":{"id":"dh0ya2eilxk0","created":1773333550040,"text":"X线管组件支持装置"},"children":[{"data":{"id":"dh0ybipwteo0","created":1773333663922,"text":"立柱式支持装置","note":"落地式支持装置"},"children":[{"dat